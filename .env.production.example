# ─────────────────────────────────────────────────────────────────────────────
# Context Pack Engine — PRODUCTION environment template
# Copy values into Vercel (web) and Render (worker). See PRODUCTION.md.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Public URL of the Vercel deployment (no trailing slash)
APP_BASE_URL=https://your-app.vercel.app
AUTH_URL=https://your-app.vercel.app
AUTH_SECRET=

# Neon — pooled URL on Vercel/Render runtime; direct URL for migrations only
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/cpe?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/cpe?sslmode=require

# Upstash Redis (use rediss:// TLS URL)
REDIS_URL=rediss://default:PASSWORD@xxxx.upstash.io:6379

# Slack app (same app for web OAuth + bot)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=

# Connectors + LLM
GITHUB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDINGS_PROVIDER=openai

# Worker tuning
WORKER_CONCURRENCY=4
