# ─────────────────────────────────────────────────────────────────────────────
# Render WORKER env template (Background Worker — NOT Web Service)
# Web app lives on Vercel: https://slackbrain.vercel.app
#
# Generate from your local .env:  npm run env:render
# Paste into Render → Worker → Environment → Add from .env
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
APP_BASE_URL=https://slackbrain.vercel.app

# Neon (same as Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Upstash (same REDIS_URL as Vercel — must match exactly)
REDIS_URL=rediss://default:PASSWORD@xxxx.upstash.io:6379

# Slack (worker posts Pack cards — bot token required)
SLACK_BOT_TOKEN=xoxb-...
# Optional — improves Slack search; worker starts without it
SLACK_USER_TOKEN=xoxp-...

# Connectors + AI (GITHUB_TOKEN optional — leave empty to skip GitHub)
GITHUB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=https://your-ollama-host:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDINGS_PROVIDER=ollama

WORKER_CONCURRENCY=4

RETRIEVAL_TIMEOUT_MS=9000
RETRIEVAL_TOP_K_PER_SOURCE=8
DEDUPE_COSINE_THRESHOLD=0.92
