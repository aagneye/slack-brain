# ─────────────────────────────────────────────────────────────────────────────
# Vercel production import template (SAFE TO COMMIT — no real secrets)
#
# Easiest path: run `npm run env:vercel` from your filled .env → uploads .env.vercel
# Or copy this file, fill values, import in Vercel → Environment Variables → Import .env
#
# Custom domain: https://creator.tmi.production (add in Vercel → Domains)
# Guide: docs/DEPLOY-SLACK-VERCEL-RENDER.md
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
APP_BASE_URL=https://creator.tmi.production
AUTH_URL=https://creator.tmi.production
AUTH_SECRET=generate-with-openssl-rand-base64-32

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

REDIS_URL=rediss://default:PASSWORD@xxxx.upstash.io:6379

# Slack — Request URLs use APP_BASE_URL above
#   https://creator.tmi.production/api/auth/callback/slack
#   https://creator.tmi.production/api/slack/commands
#   https://creator.tmi.production/api/slack/interactions
#   https://creator.tmi.production/api/slack/events
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=

GITHUB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=https://your-ollama-host:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDINGS_PROVIDER=ollama

RETRIEVAL_TIMEOUT_MS=9000
RETRIEVAL_TOP_K_PER_SOURCE=8
DEDUPE_COSINE_THRESHOLD=0.92
