{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm ci --include=dev",
  "buildCommand": "cd ../.. && npm run db:generate -w @cpe/db && npm run build -w @cpe/web",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/slack/**/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/health/route.ts": {
      "maxDuration": 15
    }
  }
}
