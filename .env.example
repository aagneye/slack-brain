# ─────────────────────────────────────────────────────────────────────────────
# Context Pack Engine — environment variables
# Copy to .env and fill in. See setup.md for local dev; PRODUCTION.md for deploy.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Auth.js (web sessions). Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Database — PostgreSQL + pgvector (local Docker, Neon, or Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cpe?schema=public
# Neon requires a direct (non-pooled) URL for migrations:
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/cpe?schema=public

# Redis (local Docker or Upstash)
REDIS_URL=redis://localhost:6379

# Slack app
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
# User token (xoxp-) with search:read — NOT interchangeable with bot token
SLACK_USER_TOKEN=

# GitHub connector
GITHUB_TOKEN=

# LLM providers — use Ollama (self-hosted) or cloud APIs
# Production with Neon + Upstash: set OLLAMA_ENABLED=true and point at your Ollama host.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDINGS_PROVIDER=ollama

# Ollama (recommended when avoiding cloud LLM keys)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Pipeline tuning (optional overrides)
RETRIEVAL_TIMEOUT_MS=9000
RETRIEVAL_TOP_K_PER_SOURCE=8
DEDUPE_COSINE_THRESHOLD=0.92
